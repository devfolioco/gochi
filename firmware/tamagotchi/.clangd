# clangd config for the Arduino sketch.
# `make build` (or `make db`) writes build/compile_commands.json, which
# clangd picks up from the build/ subdir. `-xc++` tells clangd the .ino
# is C++ (it has no standard extension clangd recognizes on its own).
CompileFlags:
  Add: [-xc++]
  CompilationDatabase: build
